<section class="relative pt-48 pb-24 px-6 z-10">
  <div class="max-w-6xl mx-auto flex flex-col items-start">

    <!-- Availability badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-50 border border-zinc-200/60 text-xs font-medium text-zinc-600 mb-8 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 cursor-default group">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-zinc-950 group-hover:bg-zinc-700 transition-colors"></span>
      </span>
      Menerima proyek baru
    </div>

    <h1 class="text-5xl md:text-7xl font-medium tracking-tight max-w-4xl leading-tight mb-8 text-transparent bg-clip-text bg-gradient-to-br from-zinc-950 via-zinc-800 to-zinc-500">
      Sistem Internal yang Bikin Bisnis Anda Lebih Cepat, Lebih Murah, Lebih Andal
    </h1>

    <p class="text-lg md:text-xl max-w-2xl mb-12 leading-relaxed text-zinc-500">
      Kami bangun web & mobile app custom untuk HR, gudang, keuangan, dan operasional — khusus untuk bisnis Indonesia yang sudah lelah pakai Excel dan WhatsApp.
    </p>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="relative group">
        <div class="absolute inset-0 bg-zinc-900 rounded-full blur-md opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
        <a href="mailto:hello@pixelcraft.dev" class="relative inline-flex items-center gap-2 px-8 py-4 rounded-full text-sm font-medium transition-all duration-300 bg-zinc-950 text-white hover:bg-zinc-800 hover:scale-[1.02] active:scale-[0.98]">
          Konsultasi Gratis 60 Menit
          <iconify-icon icon="solar:arrow-right-linear" class="text-lg group-hover:translate-x-1.5 transition-transform duration-300"></iconify-icon>
        </a>
      </div>
      <a href="#what-we-built" class="inline-flex items-center gap-2 px-6 py-4 rounded-full text-sm font-medium text-zinc-500 hover:text-zinc-950 hover:bg-zinc-100 transition-all duration-300">
        Lihat Case Study
        <iconify-icon icon="solar:arrow-down-linear" class="text-base"></iconify-icon>
      </a>
    </div>

  </div>
</section>
