---
const services = [
  {
    num: '01',
    title: 'Internal Dashboards',
    desc: 'Real-time operational visibility. Custom-built to surface the metrics that matter to your specific workflows.',
  },
  {
    num: '02',
    title: 'Workflow Automation',
    desc: 'Approval chains, task routing, notifications — engineered to match your process exactly as it exists.',
  },
  {
    num: '03',
    title: 'Mobile Field Tools',
    desc: 'Native and progressive web apps for teams in the field. Works offline. Syncs when connected.',
  },
  {
    num: '04',
    title: 'Data & Reporting Systems',
    desc: 'Replace fragmented spreadsheets with a single source of truth. Structured, searchable, exportable.',
  },
];
---

<section class="what" id="what-we-do">
  <div class="what-header">
    <span class="label">What We Do</span>
    <h2 class="what-title">PURPOSE-BUILT<br/><span class="accent">INTERNAL APPLICATIONS</span></h2>
  </div>

  <div class="what-intro">
    <p>
      Pixelcraft builds web and mobile applications designed specifically for
      how your teams operate. Every project is built from the ground up.
      No templates. No unnecessary features. No license fees for tools your
      people won't use.
    </p>
  </div>

  <div class="services-grid">
    {services.map((s) => (
      <div class="service-card">
        <span class="service-num label accent">{s.num}</span>
        <h3 class="service-title">{s.title}</h3>
        <p class="service-desc">{s.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .what {
    border-bottom: var(--border);
    background: var(--color-bg-inv);
    color: var(--color-text-inv);
  }

  .what-header {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: end;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border-bottom: var(--border-inv);
  }

  .what-header .label { color: var(--color-accent); }

  .what-title {
    font-size: var(--font-size-h2);
  }

  .what-intro {
    padding: var(--space-lg);
    max-width: 60ch;
    border-bottom: var(--border-inv);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .service-card {
    padding: var(--space-lg) var(--space);
    border-right: var(--border-inv);
    display: flex;
    flex-direction: column;
    gap: var(--space);
  }

  .service-card:last-child { border-right: none; }

  .service-card:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .service-card:hover .service-num { color: var(--color-bg); }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .service-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .service-card:nth-child(2) { border-right: none; }
    .service-card:nth-child(3) { border-top: var(--border-inv); }
    .service-card:nth-child(4) { border-top: var(--border-inv); border-right: none; }
  }

  @media (max-width: 540px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-card { border-right: none; border-top: var(--border-inv); }
  }
</style>
