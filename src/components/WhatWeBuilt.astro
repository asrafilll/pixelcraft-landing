---
const projects = [
  {
    icon: 'solar:smartphone-update-linear',
    title: 'Field Inspection Tool',
    desc: 'A mobile application that replaced paper-based inspection forms for an operations team. Reports generate automatically; sign-offs are captured in real time.',
  },
  {
    icon: 'solar:cart-large-minimalistic-linear',
    title: 'Procurement Dashboard',
    desc: 'A web portal consolidating procurement requests, vendor approvals, and budget tracking across multiple departments — replacing a multi-spreadsheet process.',
  },
  {
    icon: 'solar:users-group-two-rounded-linear',
    title: 'HR Onboarding Platform',
    desc: 'A structured onboarding workflow tool that guides new hires through compliance, access provisioning, and team introductions — reducing coordination time.',
  },
  {
    icon: 'solar:chart-square-linear',
    title: 'Executive Reporting Suite',
    desc: 'A real-time dashboard aggregating operational KPIs from multiple data sources, formatted for C-suite review without manual preparation each week.',
  },
];
---

<section class="py-32 px-6 relative z-10 bg-zinc-50/30 border-t border-zinc-100 backdrop-blur-sm overflow-hidden" id="what-we-built">
  <!-- Decorative rings -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/3 w-96 h-96 border border-zinc-200/50 rounded-full opacity-50 pointer-events-none"></div>
  <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/4 w-[30rem] h-[30rem] border border-zinc-200/30 rounded-full opacity-50 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-16 max-w-2xl text-zinc-950">
      Applications That Solve Real Operational Problems
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <div class="group relative p-8 rounded-2xl border bg-white border-zinc-200/60 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 overflow-hidden cursor-default">
          <div class="absolute inset-0 bg-gradient-to-br from-zinc-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          <div class="relative z-10">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
              <div class="flex items-center gap-4 text-zinc-950">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-zinc-100 group-hover:bg-zinc-950 group-hover:text-white transition-colors duration-500">
                  <iconify-icon icon={p.icon} class="text-xl" style="stroke-width: 1.5;"></iconify-icon>
                </div>
                <h3 class="text-xl font-medium tracking-tight">{p.title}</h3>
              </div>
              <iconify-icon icon="solar:arrow-right-up-linear" class="text-xl text-zinc-300 opacity-0 -translate-x-2 translate-y-2 group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0 transition-all duration-500"></iconify-icon>
            </div>
            <p class="text-sm leading-relaxed text-zinc-500 group-hover:text-zinc-600 transition-colors duration-300">
              {p.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
